    "inventory_db = {\n",
    "        \"laptop\": {\"stock\": 5, \"base_price\": 1200},\n",
    "        \"monitor\": {\"stock\": 0, \"base_price\": 300},\n",
    "        \"keyboard\": {\"stock\": 25, \"base_price\": 80}\n",
